import openpyxl
from openpyxl.styles import Font, Alignment, PatternFill, Border, Side
from openpyxl.utils import get_column_letter

wb = openpyxl.Workbook()
ws = wb.active
ws.title = "Placement Data"

# Define headers exactly as requested
headers = [
    "Company Name",
    "Company Type",
    "Campus Date & Time",
    "Last Registration Date",
    "Package Min",
    "Package Max",
    "Package Avg",
    "Work Location",
    "Job Profile",
    "Eligibility Criteria 10th %",
    "Eligibility Criteria 12th %",
    "Eligibility Criteria CGPA/CPI",
    "Eligibility Criteria Backlog",
    "Eligibility Criteria Gap",
    "Eligibility Criteria Branch",
    "Eligibility Criteria Course",
    "Selection Process",
    "Number of Rounds",
    "Required Documents",
    "Venue",
    "Bond",
    "Stipend",
    "Other Info"
]

# Style headers
header_font = Font(bold=True, color="FFFFFF", size=11)
header_fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
header_alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
thin_border = Border(
    left=Side(style='thin'),
    right=Side(style='thin'),
    top=Side(style='thin'),
    bottom=Side(style='thin')
)

for col, header in enumerate(headers, 1):
    cell = ws.cell(row=1, column=col, value=header)
    cell.font = header_font
    cell.fill = header_fill
    cell.alignment = header_alignment
    cell.border = thin_border

