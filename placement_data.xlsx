# Write data rows
for row_idx, company in enumerate(companies_data, 2):
    for col_idx, header in enumerate(headers, 1):
        cell = ws.cell(row=row_idx, column=col_idx, value=company.get(header, ""))
        cell.border = thin_border
        cell.alignment = Alignment(vertical="center", wrap_text=True)

# Adjust column widths
column_widths = {
    'A': 25,  # Company Name
    'B': 15,  # Company Type
    'C': 25,  # Campus Date & Time
    'D': 22,  # Last Registration Date
    'E': 12,  # Package Min
    'F': 12,  # Package Max
    'G': 12,  # Package Avg
    'H': 30,  # Work Location
    'I': 30,  # Job Profile
    'J': 18,  # Eligibility 10th %
    'K': 18,  # Eligibility 12th %
    'L': 20,  # Eligibility CGPA/CPI
    'M': 20,  # Eligibility Backlog
    'N': 15,  # Eligibility Gap
    'O': 20,  # Eligibility Branch
    'P': 20,  # Eligibility Course
    'Q': 20,  # Selection Process
    'R': 15,  # Number of Rounds
    'S': 20,  # Required Documents
    'T': 25,  # Venue
    'U': 15,  # Bond
    'V': 15,  # Stipend
    'W': 35,  # Other Info
}

for col_letter, width in column_widths.items():
    ws.column_dimensions[col_letter].width = width

# Freeze header row
ws.freeze_panes = 'A2'

# Save
wb.save('/Users/mihirmithani/Downloads/Placement/placement_data.xlsx')
